{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!dist",
			"!node_modules",
			"!coverage",
			"!examples/gtd-client/dist",
			"!examples/gtd-client/node_modules"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error"
			}
		}
	}
}
