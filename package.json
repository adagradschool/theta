{
	"name": "@adagradschool/theta",
	"version": "0.0.0",
	"description": "Browser-first coding agent workspace runtime",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./browser": {
			"types": "./dist/browser.d.ts",
			"import": "./dist/browser.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"docs"
	],
	"scripts": {
		"clean": "rm -rf dist coverage",
		"build": "tsc -p tsconfig.build.json",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"typecheck": "tsc --noEmit",
		"test": "vitest --run",
		"test:browser": "node scripts/browser-smoke.mjs",
		"check": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run test:browser",
		"prepublishOnly": "npm run clean && npm run build && npm run check"
	},
	"keywords": [
		"agent",
		"browser",
		"coding-agent",
		"workspace",
		"llm"
	],
	"author": "adagradschool",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/adagradschool/theta.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"happy-dom": "20.10.6",
		"pg": "^8.22.0",
		"playwright": "1.61.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"typescript": "5.9.3",
		"vitest": "4.1.9"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "^0.79.9",
		"@earendil-works/pi-ai": "^0.79.9",
		"@electric-sql/pglite": "0.5.3",
		"@electric-sql/pglite-sync": "^0.6.3"
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	}
}
